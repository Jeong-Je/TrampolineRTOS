/* Running the following example:
 * just call goil a first time using the command line:
 * goil --target=avr/arduino/uno --templates=../../../../goil/templates/ serial.oil
 * you may have to update ARDUINO section (l.13) for your configuration.
 *
 */

OIL_VERSION = "2.5" : "test" ;

CPU test {    
  OS config {
    STATUS = STANDARD;
    BUILD = TRUE {
      TRAMPOLINE_BASE_PATH = "../..";
      APP_NAME = "base";
      APP_SRC = "bsw.cpp";
      APP_SRC = "asw.c";
      LDFLAGS = "-Wl,-Map=counter.map";
      CPPCOMPILER = "avr-g++";
      COMPILER = "avr-gcc";
      LINKER = "avr-gcc";
      ASSEMBLER = "avr-gcc";
      COPIER = "avr-objcopy";
      SYSTEM = PYTHON;
      LIBRARY = serial;

    };
    SYSTEM_CALL = TRUE;
  };

  APPMODE stdAppmode {};

  /* The following code block is for basic features of the labs */
  COUNTER DefaultTimer {
    SOURCE = TIMER2_OVF;
    TICKSPERBASE = 1;
    MAXALLOWEDVALUE = 2000;
    MINCYCLE = 1;
  };

  ALARM TimerAlarm {
    COUNTER= DefaultTimer;
    ACTION = ACTIVATETASK {
      TASK = TickPrint;
    };
    AUTOSTART = TRUE {
      // note: no more than 255 => MAXALLOWEDVALUE in counter
      ALARMTIME = 977; 
      CYCLETIME = 977; //activated each 1000 ms
      APPMODE = stdAppmode;
    };
  };

  TASK TickPrint {
    PRIORITY = 20;
    AUTOSTART = FALSE; 
    ACTIVATION = 1;
    SCHEDULE = FULL;
    STACKSIZE = 256;
  };
  /* The above code block is for basic features of the labs */

  /* Fill up your code in here */
  EVENT Event1 { MASK = AUTO; };
  EVENT Event2 { MASK = AUTO; };

  TASK Task1 {
    PRIORITY = 1;
    ACTIVATION = 1;
    AUTOSTART = FALSE;
    SCHEDULE = FULL;
    STACKSIZE = 256;
  };

  TASK Task2 {
    PRIORITY = 2;
    ACTIVATION = 1;
    AUTOSTART = FALSE;
    SCHEDULE = FULL;
    STACKSIZE = 256;
    EVENT = Event1;
    EVENT = Event2;
  };

  TASK Task3 {
    PRIORITY = 3;
    ACTIVATION = 1;
    AUTOSTART = FALSE;
    SCHEDULE = FULL;
    STACKSIZE = 64;
  };

  COUNTER counter1 
  {
    SOURCE = TIMER1_OVF;
    TICKSPERBASE = 1;
    MAXALLOWEDVALUE = 65535;
    MINCYCLE = 1;
  };

  ALARM alarm1 
  {
    COUNTER = counter1;
    ACTION = ACTIVATETASK {
      TASK = Task1;
    };
    AUTOSTART = TRUE {
      ALARMTIME = 5;
      CYCLETIME = 10;
      APPMODE = stdAppmode;
    };
  };


  ALARM alarm2
  {
    COUNTER = counter1;
    ACTION = ACTIVATETASK {
      TASK = Task2;
    };
    AUTOSTART = TRUE {
      ALARMTIME = 5;
      CYCLETIME = 20;
      APPMODE = stdAppmode;
    };
  };

  ALARM alarm3   
  {
    COUNTER = counter1;
    ACTION = SETEVENT {
      TASK = Task2;
      EVENT = Event1;
    };
    AUTOSTART = TRUE {
      ALARMTIME = 15;
      CYCLETIME = 40;
      APPMODE = stdAppmode;
    };
  };

  ALARM alarm4 
  {
    COUNTER = counter1;
    ACTION = SETEVENT {
      TASK = Task2;
      EVENT = Event2;
    };
    AUTOSTART = TRUE {
      ALARMTIME = 35;
      CYCLETIME = 40;
      APPMODE = stdAppmode;
    };
  };


};
